CXX := g++
CC := gcc
CXXFLAGS := -std=c++11 -Wall -Wextra -O2 -I../mapjson
CFLAGS := -std=c99 -Wall -Wextra -O2 -I../../test/theft/inc

# Source files
LIB_SOURCES := map_converter.cpp ../mapjson/json11.cpp
MAIN_SOURCE := main.cpp
TEST_SOURCE := test_converter.cpp
PROPERTY_TEST_SOURCE := test_property_28_roundtrip.c
PROPERTY_TEST_9_SOURCE := test_property_9_tileset_validity.c
PROPERTY_TEST_10_SOURCE := test_property_10_script_conversion.c
PROPERTY_TEST_11_SOURCE := test_property_11_trainer_reward.c
PROPERTY_TEST_12_13_SOURCE := test_property_12_13_encounter_conversion.c
PROPERTY_TEST_5_6_7_25_26_SOURCE := test_property_5_6_7_25_26_validation.c
PROPERTY_TEST_8_SOURCE := test_property_8_error_logging.c
TILESET_TEST_SOURCE := test_tileset_converter.c
TILESET_UNIT_TEST_SOURCE := test_tileset_unit.c
ENCOUNTER_TEST_SOURCE := test_encounter_converter.c
VALIDATION_TEST_SOURCE := test_validation_engine.c
ERROR_LOGGING_TEST_SOURCE := test_error_logging.c
C_LIB_SOURCE := map_converter.c
HEADERS := map_converter.h ../mapjson/json11.h

# Theft library
THEFT_LIB := ../../test/theft/build/libtheft.a

# Output
TARGET := map_converter
TEST_TARGET := test_converter
PROPERTY_TEST_TARGET := test_property_28_roundtrip
PROPERTY_TEST_9_TARGET := test_property_9_tileset_validity
PROPERTY_TEST_10_TARGET := test_property_10_script_conversion
PROPERTY_TEST_11_TARGET := test_property_11_trainer_reward
PROPERTY_TEST_12_13_TARGET := test_property_12_13_encounter_conversion
PROPERTY_TEST_5_6_7_25_26_TARGET := test_property_5_6_7_25_26_validation
PROPERTY_TEST_8_TARGET := test_property_8_error_logging
TILESET_TEST_TARGET := test_tileset_converter
TILESET_UNIT_TEST_TARGET := test_tileset_unit
ENCOUNTER_TEST_TARGET := test_encounter_converter
VALIDATION_TEST_TARGET := test_validation_engine
ERROR_LOGGING_TEST_TARGET := test_error_logging

# Platform-specific settings
ifeq ($(OS),Windows_NT)
    TARGET := $(TARGET).exe
    TEST_TARGET := $(TEST_TARGET).exe
    PROPERTY_TEST_TARGET := $(PROPERTY_TEST_TARGET).exe
    PROPERTY_TEST_9_TARGET := $(PROPERTY_TEST_9_TARGET).exe
    PROPERTY_TEST_10_TARGET := $(PROPERTY_TEST_10_TARGET).exe
    PROPERTY_TEST_11_TARGET := $(PROPERTY_TEST_11_TARGET).exe
    PROPERTY_TEST_12_13_TARGET := $(PROPERTY_TEST_12_13_TARGET).exe
    PROPERTY_TEST_5_6_7_25_26_TARGET := $(PROPERTY_TEST_5_6_7_25_26_TARGET).exe
    PROPERTY_TEST_8_TARGET := $(PROPERTY_TEST_8_TARGET).exe
    TILESET_TEST_TARGET := $(TILESET_TEST_TARGET).exe
    TILESET_UNIT_TEST_TARGET := $(TILESET_UNIT_TEST_TARGET).exe
    ENCOUNTER_TEST_TARGET := $(ENCOUNTER_TEST_TARGET).exe
    VALIDATION_TEST_TARGET := $(VALIDATION_TEST_TARGET).exe
    ERROR_LOGGING_TEST_TARGET := $(ERROR_LOGGING_TEST_TARGET).exe
    RM := del /Q
else
    RM := rm -f
endif

all: $(TARGET) $(TEST_TARGET) $(PROPERTY_TEST_TARGET) $(PROPERTY_TEST_9_TARGET) $(PROPERTY_TEST_10_TARGET) $(PROPERTY_TEST_11_TARGET) $(PROPERTY_TEST_12_13_TARGET) $(PROPERTY_TEST_5_6_7_25_26_TARGET) $(PROPERTY_TEST_8_TARGET) $(TILESET_TEST_TARGET) $(TILESET_UNIT_TEST_TARGET) $(ENCOUNTER_TEST_TARGET) $(VALIDATION_TEST_TARGET) $(ERROR_LOGGING_TEST_TARGET)

$(TARGET): $(MAIN_SOURCE) $(LIB_SOURCES) $(HEADERS)
	$(CXX) $(CXXFLAGS) $(MAIN_SOURCE) $(LIB_SOURCES) -o $(TARGET)

$(TEST_TARGET): $(TEST_SOURCE) $(LIB_SOURCES) $(HEADERS)
	$(CXX) $(CXXFLAGS) $(TEST_SOURCE) $(LIB_SOURCES) -o $(TEST_TARGET)

# Build Theft library first if needed
$(THEFT_LIB):
	cd ../../test/theft && $(MAKE)

$(PROPERTY_TEST_TARGET): $(PROPERTY_TEST_SOURCE) $(C_LIB_SOURCE) $(HEADERS) $(THEFT_LIB)
	$(CC) $(CFLAGS) $(PROPERTY_TEST_SOURCE) $(C_LIB_SOURCE) -o $(PROPERTY_TEST_TARGET) $(THEFT_LIB)

$(PROPERTY_TEST_9_TARGET): $(PROPERTY_TEST_9_SOURCE) $(C_LIB_SOURCE) $(HEADERS) $(THEFT_LIB)
	$(CC) $(CFLAGS) $(PROPERTY_TEST_9_SOURCE) $(C_LIB_SOURCE) -o $(PROPERTY_TEST_9_TARGET) $(THEFT_LIB)

$(PROPERTY_TEST_10_TARGET): $(PROPERTY_TEST_10_SOURCE) $(C_LIB_SOURCE) $(HEADERS) $(THEFT_LIB)
	$(CC) $(CFLAGS) $(PROPERTY_TEST_10_SOURCE) $(C_LIB_SOURCE) -o $(PROPERTY_TEST_10_TARGET) $(THEFT_LIB)

$(PROPERTY_TEST_11_TARGET): $(PROPERTY_TEST_11_SOURCE) $(C_LIB_SOURCE) $(HEADERS) $(THEFT_LIB)
	$(CC) $(CFLAGS) $(PROPERTY_TEST_11_SOURCE) $(C_LIB_SOURCE) -o $(PROPERTY_TEST_11_TARGET) $(THEFT_LIB)

$(PROPERTY_TEST_12_13_TARGET): $(PROPERTY_TEST_12_13_SOURCE) $(C_LIB_SOURCE) $(HEADERS) $(THEFT_LIB)
	$(CC) $(CFLAGS) $(PROPERTY_TEST_12_13_SOURCE) $(C_LIB_SOURCE) -o $(PROPERTY_TEST_12_13_TARGET) $(THEFT_LIB)

$(PROPERTY_TEST_5_6_7_25_26_TARGET): $(PROPERTY_TEST_5_6_7_25_26_SOURCE) $(C_LIB_SOURCE) $(HEADERS) $(THEFT_LIB)
	$(CC) $(CFLAGS) $(PROPERTY_TEST_5_6_7_25_26_SOURCE) $(C_LIB_SOURCE) -o $(PROPERTY_TEST_5_6_7_25_26_TARGET) $(THEFT_LIB)

$(PROPERTY_TEST_8_TARGET): $(PROPERTY_TEST_8_SOURCE) $(C_LIB_SOURCE) $(HEADERS) $(THEFT_LIB)
	$(CC) $(CFLAGS) $(PROPERTY_TEST_8_SOURCE) $(C_LIB_SOURCE) -o $(PROPERTY_TEST_8_TARGET) $(THEFT_LIB)

$(TILESET_TEST_TARGET): $(TILESET_TEST_SOURCE) $(C_LIB_SOURCE) $(HEADERS)
	$(CC) $(CFLAGS) $(TILESET_TEST_SOURCE) $(C_LIB_SOURCE) -o $(TILESET_TEST_TARGET)

$(TILESET_UNIT_TEST_TARGET): $(TILESET_UNIT_TEST_SOURCE) $(C_LIB_SOURCE) $(HEADERS)
	$(CC) $(CFLAGS) $(TILESET_UNIT_TEST_SOURCE) $(C_LIB_SOURCE) -o $(TILESET_UNIT_TEST_TARGET)

$(ENCOUNTER_TEST_TARGET): $(ENCOUNTER_TEST_SOURCE) $(C_LIB_SOURCE) $(HEADERS)
	$(CC) $(CFLAGS) $(ENCOUNTER_TEST_SOURCE) $(C_LIB_SOURCE) -o $(ENCOUNTER_TEST_TARGET)

$(VALIDATION_TEST_TARGET): $(VALIDATION_TEST_SOURCE) $(C_LIB_SOURCE) $(HEADERS)
	$(CC) $(CFLAGS) $(VALIDATION_TEST_SOURCE) $(C_LIB_SOURCE) -o $(VALIDATION_TEST_TARGET)

$(ERROR_LOGGING_TEST_TARGET): $(ERROR_LOGGING_TEST_SOURCE) $(C_LIB_SOURCE) $(HEADERS)
	$(CC) $(CFLAGS) $(ERROR_LOGGING_TEST_SOURCE) $(C_LIB_SOURCE) -o $(ERROR_LOGGING_TEST_TARGET)

clean:
	$(RM) $(TARGET) $(TEST_TARGET) $(PROPERTY_TEST_TARGET) $(PROPERTY_TEST_9_TARGET) $(PROPERTY_TEST_10_TARGET) $(PROPERTY_TEST_11_TARGET) $(PROPERTY_TEST_12_13_TARGET) $(PROPERTY_TEST_5_6_7_25_26_TARGET) $(PROPERTY_TEST_8_TARGET) $(TILESET_TEST_TARGET) $(TILESET_UNIT_TEST_TARGET) $(ENCOUNTER_TEST_TARGET) $(VALIDATION_TEST_TARGET) $(ERROR_LOGGING_TEST_TARGET)

.PHONY: all clean
